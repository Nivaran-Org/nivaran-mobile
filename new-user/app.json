{
  "expo": {
    "name": "NIVARAN",
    "slug": "nivaran",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.nivaran"
    },
   "android": {
  "package": "com.nitintheguy.nivaranmobile",
  "namespace": "com.nitintheguy.nivaranmobile",
  "minSdkVersion": 23,
  "newArchEnabled": false,
  "permissions": [
    "android.permission.CAMERA",
    "android.permission.RECORD_AUDIO",
    "android.permission.ACCESS_COARSE_LOCATION",
    "android.permission.ACCESS_FINE_LOCATION"
  ],
  "adaptiveIcon": {
    "foregroundImage": "./assets/images/android-icon-foreground.png",
    "backgroundImage": "./assets/images/android-icon-background.png",
    "backgroundColor": "#ffffff"
  }
},
    "web": {},
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NIVARAN to access your camera to take photos of civic issues."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow NIVARAN to access your location to report civic issues accurately."
        }
      ]
    ],
    "scheme": "nivaran",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85a69da4-4f0d-4809-9ee8-7e3234e742fe"
      }
    }
  }
}
